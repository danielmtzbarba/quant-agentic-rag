APP_NAME=stock-agent-rag
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=hybrid
APP_HOST=0.0.0.0
APP_PORT=8000

OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
THESIS_STORAGE_PROVIDER=local
THESIS_ARTIFACT_BUCKET=thesis-artifacts
THESIS_ARTIFACT_LOCAL_MIRROR=true
THESIS_ARTIFACT_BASE_DIR=./data/reports
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_ENDPOINT_URL=
S3_FORCE_PATH_STYLE=false

DATA_DIR=./data
RAG_CORPUS_DIR=./data/chunks
DEFAULT_TOP_K=4
DATABASE_URL=
DB_ECHO=false
DB_SCHEMA=rag
SEC_COMPANY_NAME=Quant Agentic RAG
SEC_EMAIL_ADDRESS=you@example.com
SEC_METADATA_VERSION=1.0
VANTAGE_API_KEY=your_vantage_key
VANTAGE_BASE_URL=https://www.alphavantage.co/query
TRANSCRIPT_METADATA_VERSION=1.0
NEWS_METADATA_VERSION=1.0
TRANSCRIPT_HTTP_TIMEOUT_S=30
TRANSCRIPT_HTTP_MAX_RETRIES=3
TRANSCRIPT_HTTP_BACKOFF_BASE_S=0.75
TRANSCRIPT_HTTP_BACKOFF_MAX_S=10
VERIFIER_MAX_UNSUPPORTED_FINDINGS=0
VERIFIER_MAX_PARTIALLY_GROUNDED_FINDINGS=1
